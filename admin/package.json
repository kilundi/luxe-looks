{
  "name": "luxe-looks-admin",
  "version": "1.0.0",
  "description": "Admin panel for Luxe Looks Beauty & Cosmetics",
  "main": "server.js",
  "scripts": {
    "start": "node -r dotenv/config server.js",
    "dev": "nodemon -r dotenv/config server.js",
    "deploy": "pm2 start ecosystem.config.js --env production",
    "stop": "pm2 stop luxe-admin",
    "restart": "pm2 restart luxe-admin",
    "logs": "pm2 logs luxe-admin",
    "status": "pm2 status"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1025.0",
    "@aws-sdk/lib-storage": "^3.1025.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "node-fetch": "^3.3.2",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "typescript": "^6.0.2"
  }
}
