# Admin Server Configuration
PORT=3001

# JWT Secret - IMPORTANT: Change this in production!
# Use a strong random string (at least 32 characters)
# You can generate one at: https://generate-random.org/
JWT_SECRET=change-this-to-a-random-secure-string-in-production

# Database path (default: ./luxe_looks.db)
DB_PATH=./luxe_looks.db

# Frontend URL (for CORS) - Update for production
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:3001

# Node environment
NODE_ENV=production


